{
  "name": "mindcraft-agent",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "predev": "node -e \"var c=require('child_process');try{var o=c.execSync('netstat -ano|findstr :16288|findstr LISTENING',{encoding:'utf8'});o.split(/\\r?\\n/).filter(Boolean).forEach(l=>{var p=l.trim().split(/\\s+/).pop();if(/^\\d+$/.test(p))try{c.execSync('taskkill /F /PID '+p)}catch(e){}})}catch(e){};console.log('predev done')\"",
    "test": "node --test packages/agent/electron/pluginState.test.js packages/agent/electron/skillsSecurity.test.js packages/agent/electron/skillsCatalogCache.test.js packages/agent/electron/userDataPath.test.js packages/agent/electron/codexRuntimeConfig.test.js packages/agent/electron/codexPanelStatePaths.test.js packages/agent/electron/codexFileChangePreview.test.js packages/agent/electron/sessionRegistry.test.js tests/document-locator.test.cjs tests/codex-provider-toml.test.mjs tests/markdown-it-local-link.test.mjs tests/agent-public-renderer-boundary.test.cjs tests/agent-runtime-boundary.test.cjs tests/agent-shared-entrypoints.test.cjs tests/agent-shared-imports.test.cjs tests/agent-vue-import-boundary.test.cjs",
    "dev": "cross-env NODE_ENV=development vite --mode dev",
    "dev-ios": "cross-env NODE_ENV=development vite --mode devIos",
    "build": "vite build",
    "build:icons": "node ./build/icon-assets.js",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:serve": "concurrently -k \"yarn dev\" \"npm run electron\"",
    "electron:build": "vite build && electron-builder",
    "electron:build-beta": "cross-env NODE_ENV=testing NODE_PLATFORM=WIN node ./build/build.js --version ; vite build --mode test && electron-builder --config=./build/builder.test.json",
    "electron:build-beta-ios": "cross-env NODE_ENV=testing NODE_PLATFORM=IOS node ./build/build.js --version ; NODE_OPTIONS=--max-old-space-size=4096 vite build --mode testIos && electron-builder --config=./build/builder.test.ios.json --mac",
    "electron:build-prod": "cross-env NODE_ENV=production NODE_PLATFORM=WIN node ./build/build.js --version ; vite build --mode prod && electron-builder --config=./build/builder.prod.json",
    "electron:build-prod-ios": "cross-env NODE_ENV=production NODE_PLATFORM=IOS node ./build/build.js --version ; NODE_OPTIONS=--max-old-space-size=4096 vite build --mode prodIos && electron-builder --config=./build/builder.prod.ios.json --mac"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.117",
    "@anthropic-ai/sdk": "^0.87.0",
    "@DatatracCorporation/markdown-it-mermaid": "npm:@datatraccorporation/markdown-it-mermaid@^0.5.0",
    "@openai/codex": "^0.135.0",
    "@openai/codex-sdk": "^0.135.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.5.1",
    "compressing": "^1.10.0",
    "core-js": "^3.34.0",
    "electron-conf": "^1.2.1",
    "electron-updater": "^6.1.4",
    "idb": "^8.0.0",
    "js-web-screen-shot": "^1.9.9-rc.23",
    "katex": "^0.16.11",
    "markmap-common": "^0.17.0",
    "node-stream-zip": "^1.15.0",
    "uuid": "^11.1.0",
    "vue-i18n": "^9.14.4",
    "vue-katex-auto-render": "^0.2.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@element-plus/icons-vue": "^2.1.0",
    "@mindcraft/agent": "file:packages/agent",
    "@vitejs/plugin-vue": "^4.4.0",
    "agent-skills-cli": "^1.1.9",
    "concurrently": "^8.2.1",
    "cross-env": "^7.0.3",
    "echarts": "^5.4.3",
    "electron": "^36.2.0",
    "electron-builder": "^24.6.4",
    "element-plus": "^2.9.0",
    "form-data": "^4.0.0",
    "highlight.js": "^11.9.0",
    "js-md5": "^0.8.3",
    "markdown-it": "^13.0.2",
    "markdown-it-highlightjs": "^4.0.1",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-mathjax3": "^4.3.2",
    "markmap-lib": "^0.17.0",
    "markmap-view": "^0.17.0",
    "mermaid": "^10.9.0",
    "mitt": "^3.0.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "sass": "^1.65.1",
    "vite": "^4.4.6",
    "vite-plugin-electron": "^0.29.0",
    "vue": "^3.3.4",
    "vue-codemirror": "^6.1.1",
    "vue-demi": "^0.14.7",
    "vue-router": "^4.2.5"
  },
  "description": "轻量级多Agent集成平台",
  "keywords": [],
  "author": "Hanson Cui",
  "license": "ISC",
  "build": {
    "appId": "com.mindcraft.agent",
    "productName": "MindCraft-Agent",
    "copyright": "Copyright © 2025 GENITOP",
    "releaseInfo": {
      "releaseNotesFile": "release/release-1.0.11.md"
    },
    "extraMetadata": {
      "mode": "testing",
      "name": "mindcraft-agent",
      "platform": "WIN"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "dist/logo-app-ios.icns",
      "target": [
        "dmg",
        "zip",
        "dir"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "./database/",
        "to": "../database/"
      },
      {
        "from": "./plugins/vendors",
        "to": "vendors",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "./tools/rg",
        "to": "tools/rg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "packages/agent/**/*",
      "!node_modules/@anthropic-ai/claude-agent-sdk-win32-x64/**",
      "!node_modules/@openai/codex-win32-x64/**"
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "icon": "dist/logo-white.png",
      "target": [
        "nsis",
        "zip"
      ],
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown 文件",
          "description": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown 文件",
          "description": "Markdown Document",
          "role": "Editor"
        }
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://download.mindcraft.com.cn/MindCraft-Agent/installer/win"
      }
    ]
  },
  "overrides": {
    "canvas": "npm:browser-canvas@1.0.0"
  },
  "version": "1.0.11"
}
