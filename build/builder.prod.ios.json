{
  "appId": "com.mindcraft.agent",
  "productName": "MindCraft-Agent",
  "copyright": "Copyright © 2025 GENITOP",
  "releaseInfo": {
    "releaseNotesFile": "release/release-1.3.6.md"
  },
  "extraMetadata": {
    "mode": "production",
    "name": "mindcraft-agent",
    "platform": "IOS"
  },
  "mac": {
    "category": "public.app-category.utilities",
    "icon": "dist/logo-app-ios-white.icns",
    "target": [
      "dmg",
      "zip",
      "dir"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown 文件",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown 文件",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "extraResources": [
    {
      "from": "./plugins/vendors",
      "to": "vendors",
      "filter": [
        "**/*"
      ]
    },
      {
        "from": "./tools/rg",
        "to": "tools/rg",
        "filter": [
          "win-x64/rg.exe",
          "win-x64/LICENSE-MIT"
        ]
    }
  ],
  "files": [
    "dist/**/*",
    "electron/**/*",
    "packages/agent/**/*",
    "!node_modules/@anthropic-ai/claude-agent-sdk-darwin-*/**"
  ],
  "directories": {
    "output": "dist_electron"
  },
  "win": {
    "icon": "dist/logo-white.png",
    "target": [
      "nsis",
      "zip"
    ]
  },
  "publish": [
    {
      "provider": "generic",
      "url": "https://download.mindcraft.com.cn/MindCraft-Agent/installer/mac"
    }
  ],
  "afterSign": "build/notarize.js"
}
