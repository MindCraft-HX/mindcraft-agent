{
  "appId": "com.mindcraft.agent",
  "productName": "MindCraft-Agent-Test",
  "copyright": "Copyright © 2025 GENITOP",
  "extraMetadata": {
    "name": "mindcraft-agent",
    "mode": "testing",
    "platform": "WIN"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "extraResources": [
    {
      "from": "./database/",
      "to": "../database/"
    },
    {
      "from": "./plugins/vendors",
      "to": "vendors",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "./tools/rg",
      "to": "tools/rg",
      "filter": [
        "**/*"
      ]
    }
  ],
  "files": [
    "dist/**/*",
    "electron/**/*",
    "packages/agent/**/*",
    "!node_modules/@anthropic-ai/claude-agent-sdk-win32-x64/**",
    "!node_modules/@openai/codex-win32-x64/**"
  ],
  "directories": {
    "output": "dist_electron"
  },
  "win": {
    "icon": "dist/logo-white.png",
    "target": [
      "nsis"
    ]
  },
  "publish": [
    {
      "provider": "generic",
      "url": "https://download.mindcraft.com.cn/MindCraft/installer/win"
    }
  ]
}
