{
  "appId": "com.genitop.mindcraft.agent",
  "productName": "MindCraft-Agent-Test",
  "copyright": "Copyright © 2025 GENITOP",
  "extraMetadata": {
    "name": "mindcraft-agent",
    "mode": "testing",
    "platform": "IOS"
  },
  "mac": {
    "category": "public.app-category.utilities",
    "icon": "dist/BETA-ios-white.icns",
    "target": [
      "dmg",
      "zip",
      "dir"
    ],
    "fileAssociations": [
      { "ext": "md", "name": "Markdown 文件", "description": "Markdown Document", "role": "Editor" },
      { "ext": "markdown", "name": "Markdown 文件", "description": "Markdown Document", "role": "Editor" }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "extraResources": [
    {
      "from": "./database/",
      "to": "../database/"
    },
    {
      "from": "./plugins/vendors",
      "to": "vendors",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "./tools/rg",
      "to": "tools/rg",
      "filter": [
        "**/*"
      ]
    }
  ],
  "files": [
    "dist/**/*",
    "electron/**/*",
    "packages/agent/**/*"
  ],
  "directories": {
    "output": "dist_electron"
  },
  "win": {
    "icon": "dist/logo-white.png",
    "target": [
      "nsis",
      "zip"
    ]
  },
  "publish": [
    {
      "provider": "generic",
      "url": "https://download.mindcraft.com.cn/MindCraft-Agent/installer/mac"
    }
  ]
}